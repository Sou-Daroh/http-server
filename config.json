{
  "host": "0.0.0.0",
  "port": 8080,
  "static_dir": "./static",
  "log_file": "",
  "timeout": {
    "read": 10,
    "write": 10,
    "idle": 60
  },
  "rate_limit": {
    "enabled": false,
    "requests_per_second": 100,
    "burst": 20
  },
  "cors": {
    "enabled": false,
    "allowed_origins": ["*"],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "allowed_headers": ["Content-Type", "Authorization"]
  }
}
